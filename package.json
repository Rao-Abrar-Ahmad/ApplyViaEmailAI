{
  "name": "apply-via-email-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "vite",
    "dev:app": "vite",
    "build": "npm run typecheck && vite build",
    "build:app": "vite build",
    "deploy": "npm run build && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "oxlint app src",
    "preview": "vite preview",
    "typecheck": "tsc -p app/tsconfig.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.6.23",
    "better-auth": "^1.6.23",
    "hono": "^4.12.30",
    "kysely": "^0.29.3",
    "kysely-d1": "^0.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.1",
    "wrangler": "^4.110.0"
  }
}
